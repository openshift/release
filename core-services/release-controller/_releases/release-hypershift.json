{
    "name": "hypershift",
    "to": "hypershift-release",
    "as": "Stable",
    "message": "HyperShift continuous release - built from main branch. This release contains HyperShift operator and control plane images for hosted cluster management.",
    "mirrorPrefix": "hypershift-latest",
    "expires": "72h",
    "maxUnreadyReleases": 2,
    "minCreationIntervalSeconds": 3600,
    "referenceMode": "source",
    "pullSecretName": "source",
    "check": {},
    "publish": {
        "tag": {
            "tagRef": {
                "name": "hypershift-latest-verified"
            }
        },
        "imageStreamRef": {
            "imageStreamRef": {
                "name": "hypershift-verified",
                "namespace": "hypershift",
                "tags": [
                    "latest"
                ]
            }
        }
    },
    "verify": {}
}

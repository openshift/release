    "aws-ovn-techpreview-serial-1of3": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-aws-ovn-techpreview-serial-1of3"
      }
    },
    "aws-ovn-techpreview-serial-2of3": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-aws-ovn-techpreview-serial-2of3"
      }
    },
    "aws-ovn-techpreview-serial-3of3": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-aws-ovn-techpreview-serial-3of3"
      }
    },
    "claude-payload-agent": {
      "async": true,
      "optional": true,
      "multiJobAnalysis": true,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-claude-payload-agent"
      }
    },
    "driver-toolkit": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-nightly-5.0-e2e-aws-driver-toolkit"
      }
    },
    "install-analysis-all": {

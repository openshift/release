{
  "name": "5.0.0-0.nightly",
  "to": "release-5",
  "message": "This release contains official image builds of all code in release-5.0 (main) branches, and is updated after those builds are synced to quay.io.",
  "mirrorPrefix": "5.0-art-latest",
  "expires": "336h",
  "maxUnreadyReleases": 1,
  "minCreationIntervalSeconds": 14400,
  "referenceMode": "source",
  "pullSecretName": "source",
  "alternateImageRepository": "quay.io/openshift-release-dev/dev-release",
  "alternateImageRepositorySecretName": "release-controller-quay-mirror-secret",
  "check": {
    "OCP and Origin images should match": {
      "consistentImages": {
        "parent": "5.0.0-0.ci"
      }
    }
  },
  "publish": {
    "issues": {
      "verifyIssues": {
        "previousReleaseTag": {
          "namespace": "ocp",
          "name": "release",
          "tag": "4.22.0-rc.0"
        }
      }
    },
    "tag": {
      "tagRef": {
        "name": "5.0"
      }
    }
  },
  "verify": {
    "aggregated-aws-ovn-upgrade-5.0-micro-fips": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-nightly-5.0-e2e-aws-ovn-upgrade-fips"
      },
      "upgrade": true,
      "aggregatedProwJob": {
        "analysisJobCount": 10
      }
    },
    "aggregated-azure-ovn-upgrade-5.0-micro": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-azure-ovn-upgrade"
      },
      "upgrade": true,
      "aggregatedProwJob": {
        "analysisJobCount": 10
      }
    },
    "aggregated-gcp-ovn-rt-upgrade-5.0-major": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-upgrade-from-stable-4.22-e2e-gcp-ovn-rt-upgrade"
      },
      "upgrade": true,
      "upgradeFromRelease": {
        "candidate": {
          "stream": "nightly",
          "version": "4.22"
        }
      },
      "aggregatedProwJob": {
        "analysisJobCount": 10
      }
    },
    "aggregated-hypershift-ovn-conformance-5.0": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-hypershift-release-5.0-periodics-e2e-aws-ovn-conformance"
      },
      "aggregatedProwJob": {
        "analysisJobCount": 10
      }
    },
    "aggregated-aws-ovn-single-node-upgrade-5.0-micro": {
      "maxRetries": 2,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-aws-upgrade-ovn-single-node"
      },
      "upgrade": true,
      "aggregatedProwJob": {
        "analysisJobCount": 10
      }
    },
    "aws-ovn-serial-1of2": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-nightly-5.0-e2e-aws-ovn-serial-1of2"
      }
    },
    "aws-ovn-serial-2of2": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-nightly-5.0-e2e-aws-ovn-serial-2of2"
      }
    },
    "aws-ovn-techpreview": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-e2e-aws-ovn-techpreview"
      }

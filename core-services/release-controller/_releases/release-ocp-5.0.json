      "prowJob": {
        "name": "periodic-ci-openshift-release-main-ci-5.0-upgrade-from-stable-4.22-e2e-aws-ovn-upgrade"
      },
      "upgrade": true,
      "upgradeFromRelease": {
        "candidate": {
          "stream": "nightly",
          "version": "4.22"
        }
      }
    }
  }
}

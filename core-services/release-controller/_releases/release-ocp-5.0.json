    "overall-analysis-all": {
      "maxRetries": 2,
      "multiJobAnalysis": true,
      "prowJob": {
        "name": "periodic-ci-openshift-release-main-nightly-5.0-overall-analysis-all"
      }
    },
    "fips-scan": {
      "maxRetries": 2,

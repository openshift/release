{
  "name":"5-dev-preview",
  "as": "Stable",
  "message": "This release contains amd64 official image builds of OpenShift 5 Dev Preview",
  "overrideCLIImage": "image-registry.openshift-image-registry.svc:5000/ocp/4.23:cli",
  "expires":"72h",
  "pullSecretName": "source",
  "publish":{},
  "verify":{
    "upgrade":{
      "upgrade":true,
      "maxRetries": 2,
      "prowJob":{"name":"periodic-ci-openshift-release-main-dev-preview-5-e2e-aws-ovn-upgrade"}
    },
    "upgrade-minor":{
      "upgrade":true,
      "maxRetries": 2,
      "upgradeFrom": "PreviousMinor",
      "prowJob":{"name":"periodic-ci-openshift-release-main-dev-preview-5-e2e-aws-ovn-upgrade"}
    }
  },
  "upgrade": {
    "aws": {
      "prowJob":{"name":"periodic-ci-openshift-release-main-dev-preview-5-e2e-aws-ovn-upgrade"}
    }
  }
}


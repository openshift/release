{
  "name": "5.0.0-0.nightly-multi",
  "message": "This release contains official image builds of all multi-arch code in release-5.0 (main) branches, and is updated after those builds are synced to quay.io.",
  "mirrorPrefix": "5.0-art-latest-multi",
  "expires": "336h",
  "maxUnreadyReleases": 1,
  "minCreationIntervalSeconds": 21600,
  "referenceMode": "source",
  "pullSecretName": "source",
  "alternateImageRepository": "quay.io/openshift-release-dev/dev-release",
  "alternateImageRepositorySecretName": "release-controller-quay-mirror-secret",
  "as": "Stable",
  "overrideCLIImage": "image-registry.openshift-image-registry.svc:5000/ocp/5.0-art-latest:cli",
  "check": {},
  "publish": {},
  "verify": {
    "e2e-aws-ovn-multi-x-x": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-multiarch-main-nightly-5.0-ocp-e2e-aws-ovn-multi-x-x"
      }
    },
    "hypershift-e2e-aks-multi-x-ax": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-hypershift-release-5.0-periodics-e2e-aks-multi-x-ax"
      },
      "upgrade": true,
      "upgradeFrom": "Previous"
    },
    "e2e-aws-ovn-multi-a-a": {
      "maxRetries": 1,
      "prowJob": {
        "name": "periodic-ci-openshift-multiarch-main-nightly-5.0-ocp-e2e-aws-ovn-multi-a-a"
      }
    }
  }
}

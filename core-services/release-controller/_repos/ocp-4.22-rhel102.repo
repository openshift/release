[rhel-10.2-server-ose-4.22]
name = rhel-10.2-server-ose-4.22
baseurl = https://openshift-mirror-list.ci-systems.workers.dev/enterprise/reposync/4.22/rhel-10-server-ose-rpms
enabled = 1
gpgkey = https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-release https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-beta https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-openshifthosted
sslverify = false
gpgcheck = 0
username_file = /tmp/mirror-enterprise-basic-auth/username
password_file = /tmp/mirror-enterprise-basic-auth/password
failovermethod = priority
skip_if_unavailable = true

# Yes, this is the same repo as the 4.22 plashet above but with an includepkgs.
# See https://issues.redhat.com/browse/ART-11248.
[rhel-10.2-early-kernel]
name = rhel-10.2-early-kernel
baseurl = https://openshift-mirror-list.ci-systems.workers.dev/enterprise/reposync/4.22/rhel-102-early-kernel
enabled = 1
gpgkey = https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-release https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-beta https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-openshifthosted
sslverify = false
gpgcheck = 0
username_file = /tmp/mirror-enterprise-basic-auth/username
password_file = /tmp/mirror-enterprise-basic-auth/password
failovermethod = priority
skip_if_unavailable = true
# For iptables, see https://github.com/coreos/rhel-coreos-config/issues/254
includepkgs=kernel,kernel-*,iptables,iptables-*

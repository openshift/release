[rhel-10.2-baseos]
name = rhel-10.2-baseos
baseurl = https://cdn.redhat.com/content/e4s/rhel10/10.2/x86_64/baseos/os/
enabled = 1
gpgkey = https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-release https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-beta https://mirror.ops.rhcloud.com/libra/keys/RPM-GPG-KEY-redhat-openshifthosted
sslverify = false
gpgcheck = 0
# https://projects.engineering.redhat.com/browse/RCM-65421
sslclientkey = /tmp/key/rh-cdn.pem
sslclientcert = /tmp/key/rh-cdn.pem
failovermethod = priority
skip_if_unavailable = true

[rhel-10.2-appstream]
name = rhel-10.2-appstream

slack_reporter:
- channel: '#team-hive-alert'
  job_states_to_report:
  - failure
  - error
  report_template: Job {{.Spec.Job}} failed. <{{.Status.URL}}|View logs>
  job_names:
  - e2e-aws-manual-oidc
  - e2e-azure-manual-oidc
  - e2e-gcp-manual-oidc
  excluded_job_patterns:
  - ^pull-
  - ^branch-

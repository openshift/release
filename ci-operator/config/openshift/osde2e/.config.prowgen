rehearsals:
  disabled_rehearsals:
  - aro-ovn-e2e-default
  - aro-e2e-default
  - aro-nightly-cleanup
  - aws-stage-informing-default
  - aws-prod-cleanup
  - rosa-stage-e2e-byo-vpc-proxy-install
  - rosa-stage-e2e-byo-vpc-proxy-postinstall
slack_reporter:
- channel: '#hcm-cicd-alerts'
  job_states_to_report:
  - failure
  - success
  - error
  report_template: '{{if eq .Status.State "success"}} :white_check_mark: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*.
    <{{.Status.URL}}|View logs> :white_check_mark: {{else}} :warning:  Job *{{.Spec.Job}}* ended with *{{.Status.State}}*.
    <{{.Status.URL}}|View logs> :warning: {{end}}'
  job_names:
  - aws-stage-informing-default
  - osd-aws-upgrade-latest-default-y-minus-1-to-latest-default-y
  - osd-aws-upgrade-latest-default-y-plus-1-to-latest-y
  - osd-aws-upgrade-latest-default-y-to-latest-y-plus-1
  - osd-aws-upgrade-latest-default-z-minus-1-to-latest-default-z
  - rosa-stage-e2e-byo-vpc-proxy-install
  - rosa-stage-e2e-byo-vpc-proxy-postinstall

slack_reporter:
- channel: '#hcm-cicd-alerts'
  job_states_to_report:
  - failure
  - success
  - error
  report_template: '{{if eq .Status.State "success"}} :white_check_mark: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*.
    <{{.Status.URL}}|View logs> :white_check_mark: {{else}} :warning:  Job *{{.Spec.Job}}* ended with *{{.Status.State}}*.
    <{{.Status.URL}}|View logs> :warning: {{end}}'
  job_names: []

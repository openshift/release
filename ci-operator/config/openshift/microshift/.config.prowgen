slack_reporter:
- channel: '#microshift-alerts'
  job_states_to_report:
  - failure
  - error
  report_template: ':red_jenkins_circle: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs>'
  job_names:
  - clusterbot-nightly
  - e2e-aws-ai-model-serving-nightly
  - e2e-aws-footprint-and-performance-nightly
  - e2e-aws-ovn-ocp-conformance
  - e2e-aws-ovn-ocp-conformance-optional-components
  - e2e-aws-ovn-ocp-conformance-optional-components-arm
  - e2e-aws-ovn-ocp-conformance-serial
  - e2e-aws-tests-arm-nightly
  - e2e-aws-tests-bootc-arm-nightly
  - e2e-aws-tests-bootc-nightly
  - e2e-aws-tests-cache-nightly
  - e2e-aws-tests-cache-nightly-arm
  - e2e-aws-tests-nightly
  - periodics-clusterbot-nightly
  - periodics-e2e-aws-ai-model-serving-nightly
  - periodics-e2e-aws-footprint-and-performance-nightly
  - periodics-e2e-aws-ovn-ocp-conformance
  - periodics-e2e-aws-ovn-ocp-conformance-serial
  - periodics-e2e-aws-tests-arm-nightly
  - periodics-e2e-aws-tests-bootc-arm-nightly
  - periodics-e2e-aws-tests-bootc-nightly
  - periodics-e2e-aws-tests-cache-nightly
  - periodics-e2e-aws-tests-cache-nightly-arm
  - periodics-e2e-aws-tests-nightly
  - periodics-publish-release-notes
  - periodics-rebase-on-nightlies
  - publish-release-notes
  - rebase-on-nightlies
- channel: '#microshift-alerts'
  job_states_to_report:
  - failure
  - error
  report_template: '<@here> :red_jenkins_circle: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs>'
  job_names:
  - clusterbot
  excluded_job_patterns:

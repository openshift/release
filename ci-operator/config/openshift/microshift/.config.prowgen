  - ^branch-ci-openshift-microshift-release\-4\.17-
  - ^periodic-ci-openshift-microshift-release\-4\.18-
  - ^pull-ci-openshift-microshift-release\-4\.18-
  - ^branch-ci-openshift-microshift-release\-4\.18-
  - ^periodic-ci-openshift-microshift-release\-4\.19-
  - ^pull-ci-openshift-microshift-release\-4\.19-
  - ^branch-ci-openshift-microshift-release\-4\.19-
  - ^periodic-ci-openshift-microshift-release\-4\.20-
  - ^pull-ci-openshift-microshift-release\-4\.20-
  - ^branch-ci-openshift-microshift-release\-4\.20-
  - ^periodic-ci-openshift-microshift-release\-4\.21-

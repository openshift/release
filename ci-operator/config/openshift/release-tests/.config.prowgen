slack_reporter:
- channel: '#alerts-ocp-ert'
  job_states_to_report:
  - failure
  - error
  report_template: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> Please check!
  job_names:
  - jira-notificator
- channel: '#alerts-ocp-ert'
  job_states_to_report:
  - failure
  - error
  report_template: '{{ if eq .Status.State "success" }} :green_jenkins_circle: {{ else }} :red_jenkins_circle: {{ end }} Job
    *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs>'
  job_names:
  - qe-release-gate-test

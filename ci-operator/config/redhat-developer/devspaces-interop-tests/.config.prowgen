slack_reporter:
- channel: '#devspaces-interop-testing'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :success: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :dumpster-fire: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - devspaces-aws-rosa-hypershift
  - devspaces-interop-aws
  - devspaces-interop-aws-fips
  - devspaces-interop-ibmcloud
  - devspaces-interop-ibmcloud-fips
  - devspaces-rosa-aws

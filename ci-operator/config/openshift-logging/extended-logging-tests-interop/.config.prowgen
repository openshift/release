slack_reporter:
- channel: '#ocp-logging-ci-report'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - cluster-logging-operator-rosa-aws
  - cluster-logging-operator-rosa-hypershift
  - openshift-logging-aws-rosa-hypershift
  - openshift-logging-rosa-hypershift

slack_reporter:
- channel: "#team-ossm-quality"
  job_states_to_report:
  - failure
  - error
  report_template: ':failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs>'
  job_names:
  - e2e-ocp-arm
  - e2e-next-ocp
  - istio-pr-perfscale
  - istio-periodic-perfscale
  - cr-servicemesh-aws
  - servicemesh-aws-fips

slack_reporter:
- channel: '#tektoncd-pipeline-ci'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - openshift-pipelines-aws-rosa-hypershift
  - openshift-pipelines-interop-aws
  - openshift-pipelines-interop-aws-fips
  - openshift-pipelines-interop-rosa-aws
  - openshift-pipelines-rosa-hypershift
  excluded_variants:
  - openshift-pipelines-ocp4.16-lp-rosa-classic
  - openshift-pipelines-p2p-rosa-classic
- channel: '#tektoncd-pipeline-ci'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - openshift-pipelines-interop-ibmcloud
  excluded_variants:
  - openshift-pipelines-ocp4.15-lp-interop
  - openshift-pipelines-ocp4.16-lp-interop
  - openshift-pipelines-ocp4.16-lp-rosa-classic
  - openshift-pipelines-p2p-rosa-classic
- channel: '#forum-p2p-cspi'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - openshift-pipelines-serverless-rosa-classic-416-iib
  - openshift-pipelines-serverless-rosa-classic-417-rc
  excluded_variants:
  - openshift-pipelines-ocp-4.21-lp-interop
  - openshift-pipelines-ocp-4.21-lp-interop-cr
  - openshift-pipelines-ocp4.14-lp-interop
  - openshift-pipelines-ocp4.15-lp-interop
  - openshift-pipelines-ocp4.15-lp-rosa-hypershift
  - openshift-pipelines-ocp4.16-lp-interop
  - openshift-pipelines-ocp4.16-lp-rosa-classic
  - openshift-pipelines-ocp4.16-lp-rosa-hypershift
  - openshift-pipelines-ocp4.17-lp-interop
  - openshift-pipelines-ocp4.17-lp-rosa-classic
  - openshift-pipelines-ocp4.17-lp-rosa-hypershift
  - openshift-pipelines-ocp4.18-lp-interop
  - openshift-pipelines-ocp4.19-lp-interop
  - openshift-pipelines-ocp4.19-lp-rosa-hypershift
  - openshift-pipelines-ocp4.20-lp-interop
  - openshift-pipelines-ocp4.20-lp-rosa-hypershift

slack_reporter:
- channel: '#team-dotnet-eng'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - dotnet-interop-aws
  - dotnet-interop-aws-fips
  excluded_variants:
  - dotnet-ocp4.18-lp-interop
  - rhscl-ocp4.14-lp-interop
  - rhscl-ocp4.15-lp-interop
  - rhscl-ocp4.16-lp-interop
  - rhscl-ocp4.17-lp-interop
  - rhscl-ocp4.18-lp-interop
  - rhscl-ocp4.19-lp-interop
- channel: '#team-dotnet-eng'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :green_jenkins_circle: Job *{{.Spec.Job}}*
    ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{else}} :red_jenkins_circle:
    Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs>
    {{end}}'
  job_names:
  - dotnet-interop-ibmcloud
  excluded_variants:
  - dotnet-ocp4.18-lp-interop
  - rhscl-ocp4.14-lp-interop
  - rhscl-ocp4.15-lp-interop
  - rhscl-ocp4.16-lp-interop
  - rhscl-ocp4.17-lp-interop
  - rhscl-ocp4.18-lp-interop
  - rhscl-ocp4.19-lp-interop
  excluded_job_patterns:
  - -dotnet-ocp4\.1[789]-
  - -dotnet-ocp4\.2[0-9]-
- channel: '#team-dotnet-eng'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_name_patterns:
  - ^dotnet-interop-ibmcloud$
  excluded_variants:
  - dotnet-ocp4.18-lp-interop
  - rhscl-ocp4.14-lp-interop
  - rhscl-ocp4.15-lp-interop
  - rhscl-ocp4.16-lp-interop
  - rhscl-ocp4.17-lp-interop
  - rhscl-ocp4.18-lp-interop
  - rhscl-ocp4.19-lp-interop
  excluded_job_patterns:
  - -dotnet-ocp4\.1[4-6]-
- channel: '#proj-sclorg-bots'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
    logs> {{else}} :failed: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{end}}'
  job_names:
  - rhscl-interop-aws
  - rhscl-interop-aws-fips
  excluded_variants:
  - dotnet-ocp4.13-lp-interop
  - dotnet-ocp4.14-lp-interop
  - dotnet-ocp4.15-lp-interop
  - dotnet-ocp4.16-lp-interop
  - dotnet-ocp4.17-lp-interop
  - dotnet-ocp4.18-lp-interop
  - dotnet-ocp4.19-lp-interop

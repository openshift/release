slack_reporter:
- channel: "#art-release"
  job_states_to_report:
  - failure
  - error
  report_template: |
    ':red_jenkins_circle: Job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs>'
  job_names:
  - art-konflux-delivery-repo-check
  excluded_job_patterns:
  - ^pull-

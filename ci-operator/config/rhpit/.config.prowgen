slack_reporter:
- channel: '#team-qe-lp-triage'
  job_states_to_report:
  - success
  - failure
  - error
  report_template: '{{if eq .Status.State "success"}} :slack-green: Job *{{.Spec.Job}}*
                    ended with *{{.Status.State}}*. <{{.Status.URL}}|View logs> {{else}} :failed:
                    job *{{.Spec.Job}}* ended with *{{.Status.State}}*. <{{.Status.URL}}|View
                    logs> {{end}}'
  job_names:

  - ocp-self-managed-lp-interop--fips--422
  - ocp-self-managed-lp-interop--fips--watcher-bot--422
  - opp-interop-jobs-trigger
  - opp-interop-jobs-watcher-bot-message
  - rosa-hypershift-layered-product-interop-420
  - rosa-hypershift-lp-watcher-bot-message-420

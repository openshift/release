diff --git a/ci-operator/config/openshift/multiarch/openshift-multiarch-main__nightly-4.16.yaml b/ci-operator/config/openshift/multiarch/openshift-multiarch-main__nightly-4.16.yaml
index 0a63c918078..3534e6cc53d 100644
--- a/ci-operator/config/openshift/multiarch/openshift-multiarch-main__nightly-4.16.yaml
+++ b/ci-operator/config/openshift/multiarch/openshift-multiarch-main__nightly-4.16.yaml
@@ -499,8 +499,6 @@ tests:
       VOLUME_CAPACITY: 64GB
     workflow: openshift-e2e-libvirt-upi
 - as: ocp-e2e-ovn-remote-s2s-libvirt-ppc64le
-  capabilities:
-  - power-s2s-dns
   cron: 0 12 * * 5
   steps:
     cluster_profile: libvirt-ppc64le-s2s
@@ -510,11 +508,10 @@ tests:
       ARCH: ppc64le
       BRANCH: "4.16"
       TEST_TYPE: conformance-parallel
+      USE_EXTERNAL_DNS: "true"
       USE_RAMFS: "true"
     workflow: openshift-e2e-libvirt-upi
 - as: ocp-e2e-ovn-agent-remote-s2s-libvirt-ppc64le
-  capabilities:
-  - power-s2s-dns
   cron: 0 0 2 2 *
   steps:
     cluster_profile: libvirt-ppc64le-s2s
@@ -525,12 +522,11 @@ tests:
       BRANCH: "4.16"
       INSTALLER_TYPE: agent
       TEST_TYPE: conformance-parallel
+      USE_EXTERNAL_DNS: "true"
       USE_RAMFS: "true"
       VOLUME_CAPACITY: 120G
     workflow: openshift-e2e-libvirt-upi
 - as: ocp-image-ecosystem-ovn-remote-s2s-libvirt-ppc64le
-  capabilities:
-  - power-s2s-dns
   cron: 0 0 28 1 *
   steps:
     cluster_profile: libvirt-ppc64le-s2s
@@ -540,10 +536,9 @@ tests:
       ARCH: ppc64le
       BRANCH: "4.16"
       TEST_TYPE: image-ecosystem
+      USE_EXTERNAL_DNS: "true"
     workflow: openshift-e2e-libvirt-upi
 - as: ocp-e2e-serial-ovn-remote-s2s-libvirt-ppc64le
-  capabilities:
-  - power-s2s-dns
   cron: 0 0 30 1 *
   steps:
     cluster_profile: libvirt-ppc64le-s2s
@@ -553,10 +548,9 @@ tests:
       ARCH: ppc64le
       BRANCH: "4.16"
       TEST_TYPE: conformance-serial
+      USE_EXTERNAL_DNS: "true"
     workflow: openshift-e2e-libvirt-upi
 - as: ocp-fips-ovn-remote-s2s-libvirt-ppc64le
-  capabilities:
-  - power-s2s-dns
   cron: 0 16 * * 5
   steps:
     cluster_profile: libvirt-ppc64le-s2s
@@ -567,6 +561,7 @@ tests:
       BRANCH: "4.16"
       FIPS_ENABLED: "true"
       TEST_TYPE: conformance-parallel
+      USE_EXTERNAL_DNS: "true"
     workflow: openshift-e2e-libvirt-upi-fips
 - as: ocp-e2e-ovn-ppc64le-powervs-original
   capabilities:
